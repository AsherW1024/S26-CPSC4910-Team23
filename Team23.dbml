Table Users{
  userID integer [pk]
  Email varchar(80)
  Username varchar(80)
  Password_hash varchar(128)
  TimeCreated datetime
  TimeUpdated datetime
  LastLogin datetime
  IsActive boolean
  CreatedByUserID integer [ref: > Users.userID] 
  userType varchar(1)
}

Table Sponsors{
  SponsorID integer [pk, ref: - Users.userID]
  Name varchar(80)
  OrganizationID integer [ref: < Organizations.OrganizationID]
}

Table Organizations{
  OrganizationID integer [pk]
  Name varchar(80)
  TimeCreated datetime
}

Table Drivers{
  DriverID integer [pk, ref: - Users.userID]
  Name varchar(80)
  OrganizationID integer [ref: < Organizations.OrganizationID]
  LicenseNum varchar(80)
  Points integer
}

Table Admins{
  AdminID integer [pk, ref: - Users.userID]
  Name varchar(80)
}

Table Catalog_Rules{
  RuleID integer [pk]
  OrganizationID integer [ref: - Organizations.OrganizationID]
  CreatedBy  integer [ref: > Sponsors.SponsorID]
  PointMin integer
  PointMax integer
  TimeCreated datetime
}

Table Category_Exclusion_List{
  EntryID integer [pk]
  RuleID integer [ref: > Catalog_Rules.RuleID]
  CategoryName varchar(80)
 }

Table Catalog_Items{
  OrganizationID integer [pk, ref: > Organizations.OrganizationID]
  ItemID integer [pk, ref: > Items.ItemID]
  ItemPrice double
  QuantityAvailable integer
  IsActive boolean
  AddedBy integer [ref: > Sponsors.SponsorID]
  TimeCreated datetime
  TimeUpdated datetime
}

Table Items{
  ItemID integer [pk]
  ItemName varchar(80)
  ItemDescription varchar(256)
}

Table Point_Log {
  EntryID integer [pk]
  Driver integer [ref: > Drivers.DriverID]
  ChangedBy integer [ref: > Sponsors.SponsorID]
  Delta integer
  PreviousTotal integer
  NewTotal integer
  Reason varchar(120)
  OrderID integer [ref: > Orders.OrderID]
  Date datetime
}

Table Orders {
  OrderID integer [pk]
  Driver integer [ref: > Drivers.DriverID]
  Total float
  Address varchar(200)
  Status varchar(20) 
  TimeCreated datetime
  TimeUpdated datetime
  PointsSpent integer
}

Table Order_Items_Mapping {
  OrderID integer [pk, ref: - Orders.OrderID]
  ItemID integer [pk, ref: - Items.ItemID]
  Quantity integer
  UnitPriceAtPurchase float
}

Table Categories {
  CategoryID integer [pk]
  Name varchar(80)
}

Table Item_Categories {
  ItemID integer [pk, ref: > Items.ItemID]
  CategoryID integer [pk, ref: > Categories.CategoryID]
}

Table Login_Events {
  EventID integer [pk]
  UserID integer [ref: > Users.userID]
  Timestamp datetime
  Success boolean
  IPAddress varchar(45)
  UserAgent varchar(200)
}



